# =============================================================================
# Cluster Health Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Requires: cortex-code-agent-sdk >= 1.0.0, Python 3.11+
# =============================================================================

# --- Snowflake Account ---
SNOWFLAKE_ACCOUNT=your_account_locator          # e.g. abc12345
SNOWFLAKE_HOST=your-account.snowflakecomputing.com
SNOW_CONNECTION=your_snow_cli_connection        # snow CLI connection name
REGISTRY_URL=your-org-account.registry.snowflakecomputing.com  # from SHOW IMAGE REPOSITORIES

# --- Database Objects ---
SNOWFLAKE_DATABASE=SPORTSBOOK_DW
SNOWFLAKE_SCHEMA=WAGERS
SNOWFLAKE_WAREHOUSE=CLUSTER_HEALTH_WH
TARGET_SCHEMA=SPORTSBOOK_DW.WAGERS

# --- Notification ---
NOTIFICATION_INTEGRATION=CLUSTER_HEALTH_EMAIL_INTEGRATION
NOTIFICATION_EMAIL=your-verified-email@example.com

# --- Service ---
SERVICE_BASE_URL=https://your-ingress-url.snowflakecomputing.app

# --- Authentication ---
# Generate with: openssl rand -hex 32
TOKEN_SECRET_KEY=
TOKEN_TTL_HOURS=24
